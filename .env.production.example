# ──────────────────────────────────────────────────────
# Smart Restaurant OS — Production Environment Variables
# ──────────────────────────────────────────────────────
# Copy this to .env.production and fill in real values.
# NEVER commit .env.production with real secrets.
# Used by: docker-compose.prod.yml
# Helper: npm run secrets:production
#
# VPS policy:
# - Staging/demo VPS may use demo seed data and PAYMENT_PROVIDER=mock.
# - Real production must use a real public https:// domain, real Twilio credentials,
#   generated secrets, and no demo seed data or demo credentials.

NODE_ENV=production

# ── Ports ────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000

# ── Database (required) ─────────────────────────────
POSTGRES_DB=smart_restaurant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
# For Docker compose, host is the service name "postgres"
DATABASE_URL=postgresql://postgres:YOUR_STRONG_PASSWORD@postgres:5432/smart_restaurant?schema=public

# ── Redis (required) ────────────────────────────────
# For Docker compose, host is the service name "redis"
REDIS_URL=redis://redis:6379

# ── Auth (required) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# ── Security ────────────────────────────────────────
# CORS: comma-separated explicit origins allowed to call the API.
# Behind Nginx on same host, use the public-facing HTTPS URL.
# Production rejects wildcards, "null", paths, query strings, hashes, and non-localhost http:// origins.
# Replace localhost with your final public https:// domain before live rollout.
CORS_ORIGINS=https://localhost
FRONTEND_ORIGIN=https://localhost
# API forces secure cookies when NODE_ENV=production. Use HTTPS for browser cookie flows.
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.yourdomain.com
STAFF_ACCESS_TOKEN_TTL=8h
STAFF_ACCESS_COOKIE_MAX_AGE_MS=28800000

# ── Frontend (build-time) ───────────────────────────
# Empty string = same-origin (browser API calls go through Nginx).
# Set to full URL only if web and API are on different origins.
NEXT_PUBLIC_API_BASE_URL=

# ── Optional CI/CD image deployment ─────────────────
# Use these only when the VPS should pull images published by
# .github/workflows/release-images.yml instead of building locally.
# Keep the default local-build path if you do not plan to use GHCR yet.
# API_IMAGE=ghcr.io/your-github-owner/smart-restaurant-os-api:main
# WEB_IMAGE=ghcr.io/your-github-owner/smart-restaurant-os-web:main
# AI_IMAGE=ghcr.io/your-github-owner/smart-restaurant-os-ai:main

# ── Payments ────────────────────────────────────────
# Provider: "mock" is acceptable for staging/demo VPS without external payment capture.
# Use "stripe" or another real adapter before accepting real customer payments in production.
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
GEOFENCING_ENABLED=true
GEOFENCING_DEMO_BYPASS=false
GEOFENCING_DEFAULT_RADIUS_M=100
GEOFENCING_MAX_ACCURACY_M=1000

# Stripe (only needed when PAYMENT_PROVIDER=stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Service (optional) ───────────────────────────
AI_SERVICE_URL=http://ai:8000

# ── Object Storage (MinIO) ──────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=smart-restaurant
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=REPLACE_WITH_MINIO_PASSWORD
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD

# ── Optional Monitoring Overlay ─────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# ── SMS Provider ───────────────────────────────────
# Production requires a real SMS provider for customer OTP delivery.
# These values come from your Twilio account, not from this repo.
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+15555550123
