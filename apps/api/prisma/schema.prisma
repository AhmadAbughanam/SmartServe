model Shift {
  id         String            @id @default(cuid())
  tenantId   String
  branchId   String
  staffId    String
  startTime  DateTime
  endTime    DateTime?
  status     ShiftStatus       @default(OPEN)
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch     Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  staff      Staff             @relation("ShiftOwnedByStaff", fields: [staffId], references: [id], onDelete: Restrict)
  tills      Till[]
  attendance StaffAttendance[]

  @@index([branchId, status, startTime])
  @@index([staffId, startTime])
}

model Till {
  id              String   @id @default(cuid())
  tenantId        String
  shiftId         String
  expectedCash    Decimal  @db.Decimal(12, 2)
  actualCash      Decimal  @db.Decimal(12, 2)
  difference      Decimal  @db.Decimal(12, 2)
  closedByStaffId String
  closedAt        DateTime
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift           Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  closedByStaff   Staff    @relation("TillClosedByStaff", fields: [closedByStaffId], references: [id], onDelete: Restrict)

  @@index([shiftId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  actorStaffId String
  actionCode   String
  entityType   String
  entityId     String
  timestamp    DateTime @default(now())
  beforeJson   Json?
  afterJson    Json?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  actorStaff   Staff    @relation(fields: [actorStaffId], references: [id], onDelete: Restrict)

  @@index([branchId, timestamp])
  @@index([actorStaffId, timestamp])
  @@index([entityType, entityId])
}

model OperationalEventLog {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  sessionId    String?
  tableId      String?
  orderId      String?
  actorStaffId String?
  eventType    String
  severity     String   @default("INFO")
  message      String
  metadata     Json?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  actorStaff   Staff?   @relation("OperationalEventActorStaff", fields: [actorStaffId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([sessionId, createdAt])
  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model PaymentEventLog {
  id         String   @id @default(cuid())
  tenantId   String
  branchId   String
  orderId    String?
  sessionId  String?
  paymentId  String?
  eventType  String
  provider   String?
  externalId String?
  amount     Decimal? @db.Decimal(12, 2)
  status     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([tenantId, branchId, createdAt])
  @@index([paymentId, createdAt])
  @@index([externalId])
  @@index([eventType, createdAt])
}

model OtpRequest {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int       @default(0)

  @@index([phone, expiresAt])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  deviceInfo String?
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Discount {
  id          String       @id @default(cuid())
  tenantId    String
  branchId    String?
  name        String
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(12, 2)
  scope       String       @default("ORDER") // ORDER or ITEMS
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  coupons     Coupon[]

  @@index([tenantId, branchId, isActive])
}

model Coupon {
  id                 String                    @id @default(cuid())
  tenantId           String
  code               String
  discountId         String
  maxRedemptions     Int?
  perUserLimit       Int?
  expiresAt          DateTime?
  isActive           Boolean                   @default(true)
  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  discount           Discount                  @relation(fields: [discountId], references: [id], onDelete: Restrict)
  redemptions        CouponRedemption[]
  loyaltyRedemptions LoyaltyRewardRedemption[]

  @@unique([tenantId, code])
}

model LoyaltyProgram {
  id                String          @id @default(cuid())
  tenantId          String
  name              String          @default("Default Loyalty Program")
  pointsPerCurrency Decimal         @default(1) @db.Decimal(12, 2)
  pointsPerReward   Int             @default(100)
  rewardValue       Decimal         @default(5) @db.Decimal(12, 2)
  pointExpiryMonths Int             @default(12)
  isActive          Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rewards           LoyaltyReward[]

  @@unique([tenantId])
}

model LoyaltyAccount {
  id             String                    @id @default(cuid())
  tenantId       String
  userId         String
  pointsBalance  Int                       @default(0)
  lifetimePoints Int                       @default(0)
  tier           String                    @default("BRONZE")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @default(now()) @updatedAt
  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries  LoyaltyLedgerEntry[]
  redemptions    LoyaltyRewardRedemption[]

  @@unique([tenantId, userId])
  @@index([tenantId, tier])
}

model LoyaltyLedgerEntry {
  id          String                 @id @default(cuid())
  tenantId    String
  branchId    String?
  accountId   String
  orderId     String?
  paymentId   String?
  refundId    String?
  type        LoyaltyLedgerEntryType
  points      Int
  description String?
  expiresAt   DateTime?
  createdAt   DateTime               @default(now())
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch      Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  account     LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order       Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment     Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  refund      Refund?                @relation(fields: [refundId], references: [id], onDelete: SetNull)

  @@index([tenantId, accountId, createdAt])
  @@index([paymentId])
  @@index([refundId])
}

model LoyaltyReward {
  id          String                    @id @default(cuid())
  tenantId    String
  programId   String
  name        String
  pointsCost  Int
  rewardValue Decimal                   @db.Decimal(12, 2)
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @default(now()) @updatedAt
  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  program     LoyaltyProgram            @relation(fields: [programId], references: [id], onDelete: Cascade)
  redemptions LoyaltyRewardRedemption[]

  @@index([tenantId, isActive])
}

model LoyaltyRewardRedemption {
  id          String                        @id @default(cuid())
  tenantId    String
  accountId   String
  rewardId    String
  couponId    String?
  pointsSpent Int
  status      LoyaltyRewardRedemptionStatus @default(ISSUED)
  createdAt   DateTime                      @default(now())
  redeemedAt  DateTime?
  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  account     LoyaltyAccount                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reward      LoyaltyReward                 @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  coupon      Coupon?                       @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([tenantId, accountId, createdAt])
}

model GiftCard {
  id            String                @id @default(cuid())
  tenantId      String
  code          String
  initialAmount Decimal               @db.Decimal(12, 2)
  balanceAmount Decimal               @db.Decimal(12, 2)
  status        GiftCardStatus
  expiresAt     DateTime?
  createdAt     DateTime              @default(now())
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  transactions  GiftCardTransaction[]

  @@unique([tenantId, code])
}

model StaffAttendance {
  id       String    @id @default(cuid())
  tenantId String
  branchId String
  staffId  String
  checkIn  DateTime
  checkOut DateTime?
  shiftId  String?
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  staff    Staff     @relation(fields: [staffId], references: [id], onDelete: Restrict)
  shift    Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([staffId, checkIn])
  @@index([branchId, checkIn])
}

model GeoFencingRule {
  id                  String            @id @default(cuid())
  tenantId            String
  branchId            String
  enabled             Boolean           @default(false)
  allowedRadiusMeters Int
  centerLatitude      Decimal           @db.Decimal(9, 6)
  centerLongitude     Decimal           @db.Decimal(9, 6)
  appliesTo           GeoFenceAppliesTo
  createdAt           DateTime          @default(now())
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch              Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId, enabled])
}

model UserItemStat {
  userId        String
  menuItemId    String
  timesOrdered  Int       @default(0)
  lastOrderedAt DateTime?
  avgRating     Decimal?  @db.Decimal(3, 2)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([userId, menuItemId])
}

model MenuItemFavorite {
  userId     String
  menuItemId String
  tenantId   String
  branchId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@id([userId, menuItemId, branchId])
  @@index([userId, branchId])
  @@index([tenantId, branchId])
  @@index([menuItemId])
}

// ─────────────────────────────────────────────────────
// Spec Completion Phase 1 — new models
// ─────────────────────────────────────────────────────

// 1. Branch device management
model BranchDevice {
  id               String     @id @default(cuid())
  tenantId         String
  branchId         String
  name             String
  deviceType       DeviceType
  apiKeyHash       String?
  capabilitiesJson Json?
  isActive         Boolean    @default(true)
  lastSeenAt       DateTime?
  createdAt        DateTime   @default(now())
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch     @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([branchId, name])
  @@index([branchId])
  @@index([tenantId])
}

// 2. QR / NFC access tag registry
model TableAccessTag {
  id        String        @id @default(cuid())
  tenantId  String
  branchId  String
  tableId   String
  code      String        @unique
  type      AccessTagType
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch    Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  table     Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([tableId])
}

// 3. Branch operational settings
model BranchSettings {
  branchId             String            @id
  tenantId             String
  serviceChargeEnabled Boolean           @default(false)
  serviceChargeType    ServiceChargeType @default(PERCENT)
  serviceChargeValue   Decimal           @default(0) @db.Decimal(12, 2)
  tipsEnabled          Boolean           @default(true)
  tipPresetsJson       Json?
  paymentConfigJson    Json?
  featureFlagsJson     Json?
  aiConfigJson         Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch               Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PlatformSettings {
  id                             String   @id @default("global")
  platformName                   String   @default("Smart Restaurant OS")
  supportEmail                   String?
  supportPhone                   String?
  maintenanceModeEnabled         Boolean  @default(false)
  maintenanceMessage             String?
  ownerProvisioningEnabled       Boolean  @default(true)
  auditRetentionDays             Int      @default(90)
  defaultSystemHealthWindowHours Int      @default(24)
  defaultRevenueRangeDays        Int      @default(30)
  announcementJson               Json?
  changeLogJson                  Json?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

enum TenantSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum SaasInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  OVERDUE
}

model TenantSubscription {
  id                 String                   @id @default(cuid())
  tenantId           String                   @unique
  planCode           String
  status             TenantSubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  nextInvoiceAt      DateTime?
  amount             Decimal                  @db.Decimal(12, 2)
  currency           String                   @default("USD")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices           SaasInvoice[]

  @@index([status])
  @@index([nextInvoiceAt])
}

model SaasInvoice {
  id             String            @id @default(cuid())
  tenantId       String
  subscriptionId String?
  invoiceNumber  String            @unique
  status         SaasInvoiceStatus @default(DRAFT)
  amount         Decimal           @db.Decimal(12, 2)
  currency       String            @default("USD")
  dueAt          DateTime?
  paidAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription   TenantSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([status, dueAt])
  @@index([subscriptionId])
}

// 4a. Inventory stock movement audit
model StockAdjustment {
  id               String                @id @default(cuid())
  tenantId         String
  branchId         String
  inventoryItemId  String
  delta            Decimal               @db.Decimal(12, 3)
  reason           String?
  createdByStaffId String?
  sourceType       StockAdjustmentSource @default(MANUAL)
  createdAt        DateTime              @default(now())
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  createdByStaff   Staff?                @relation("StockAdjustmentByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, createdAt])
  @@index([branchId, createdAt])
}

// 4b. Inventory low-stock alert records
model LowStockAlert {
  id                String              @id @default(cuid())
  tenantId          String
  branchId          String
  inventoryItemId   String
  thresholdSnapshot Decimal             @db.Decimal(12, 3)
  stockSnapshot     Decimal             @db.Decimal(12, 3)
  status            LowStockAlertStatus @default(OPEN)
  createdAt         DateTime            @default(now())
  resolvedAt        DateTime?
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch            Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  inventoryItem     InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([branchId, status])
  @@index([inventoryItemId])
}

// 5a. Coupon redemption tracking
model CouponRedemption {
  id         String   @id @default(cuid())
  tenantId   String
  branchId   String
  couponId   String
  userId     String?
  orderId    String?
  redeemedAt DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([branchId, redeemedAt])
}

// 5b. Gift card transaction ledger
model GiftCardTransaction {
  id               String                  @id @default(cuid())
  tenantId         String
  giftCardId       String
  orderId          String?
  type             GiftCardTransactionType
  amount           Decimal                 @db.Decimal(12, 2)
  balanceAfter     Decimal                 @db.Decimal(12, 2)
  createdAt        DateTime                @default(now())
  createdByStaffId String?
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  branchId         String
  giftCard         GiftCard                @relation(fields: [giftCardId], references: [id], onDelete: Restrict)
  order            Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdByStaff   Staff?                  @relation("GiftCardTransactionByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([giftCardId, createdAt])
  @@index([branchId, createdAt])
}

// 6. Co-purchase / recommendation statistics
model RecommendationStat {
  tenantId          String
  branchId          String
  menuItemId        String
  coPurchasedItemId String
  categoryId        String?
  count             Int       @default(0)
  lastComputedAt    DateTime  @default(now())
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch            Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  menuItem          MenuItem  @relation("RecommendationFromItem", fields: [menuItemId], references: [id], onDelete: Cascade)
  coPurchasedItem   MenuItem  @relation("RecommendationToItem", fields: [coPurchasedItemId], references: [id], onDelete: Cascade)
  category          Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@id([tenantId, branchId, menuItemId, coPurchasedItemId])
}

model RecommendationLog {
  id                  String   @id @default(cuid())
  tenantId            String
  branchId            String
  userId              String?
  sessionId           String?
  source              String   @default("MENU_RECOMMENDATION_ENGINE")
  inputCartItemIds    String[]
  recommendedItemIds  String[]
  recommendationTypes String[]
  metadata            Json?
  createdAt           DateTime @default(now())
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch              Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  session             Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([userId])
  @@index([sessionId])
}

enum RecommendationInteractionType {
  IMPRESSION
  CLICK
  ADD_TO_CART
  PURCHASED
  DISMISSED
}

model RecommendationInteraction {
  id              String                        @id @default(cuid())
  tenantId        String
  branchId        String
  userId          String?
  sessionId       String?
  menuItemId      String
  interactionType RecommendationInteractionType
  surface         String?
  traceId         String?
  createdAt       DateTime                      @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  session  Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, createdAt])
  @@index([traceId])
}

model MenuChatLog {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  userId           String?
  sessionId        String?
  messageIntent    String?
  messageHash      String?
  messagePreview   String?
  suggestedItemIds Json
  safetyNotes      Json?
  usedAiService    Boolean  @default(false)
  usedFallback     Boolean  @default(false)
  metadata         Json?
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  session          Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([userId])
  @@index([sessionId])
}

model DemandForecastLog {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  requestedById   String?
  forecastDate    DateTime
  lookbackDays    Int
  categoryId      String?
  expectedOrders  Int
  expectedRevenue Decimal? @db.Decimal(12, 2)
  metadata        Json?
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  requestedBy     Staff?   @relation("DemandForecastRequestedByStaff", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([requestedById])
}

model DemandForecastAccuracy {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  date         DateTime // The target date for which accuracy was measured
  lookbackDays Int // What was the lookback days setting of the forecast

  forecastedOrders  Int
  actualOrders      Int
  forecastedRevenue Decimal @db.Decimal(12, 2)
  actualRevenue     Decimal @db.Decimal(12, 2)

  // Stored as JSON: array of { menuItemId, expectedQty, actualQty }
  itemAccuracy Json

  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, branchId, date])
}

model ReviewSentimentLog {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  requestedById String?
  fromDate      DateTime
  toDate        DateTime
  menuItemId    String?
  totalReviews  Int
  averageRating Decimal? @db.Decimal(3, 2)
  sentiment     String
  commonIssues  Json?
  affectedItems Json?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  requestedBy   Staff?   @relation("ReviewSentimentRequestedByStaff", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([requestedById])
}

model BusinessInsightLog {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  requestedById String?
  scope         String
  fromDate      DateTime
  toDate        DateTime
  insightCount  Int
  categories    Json?
  priorities    Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requestedBy   Staff?   @relation("BusinessInsightRequestedByStaff", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([requestedById])
}

// 7. Review issue tags (normalized from free-form JSON)
model ReviewIssueTag {
  id       String @id @default(cuid())
  reviewId String
  tag      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([tag])
}

// 8. Waste / remake records for kitchen incident tracking
model WasteRecord {
  id               String      @id @default(cuid())
  tenantId         String
  branchId         String
  orderId          String?
  orderItemId      String?
  menuItemId       String
  stationId        String?
  type             WasteType
  quantity         Int         @default(1)
  reasonCode       WasteReason
  note             String?
  createdByStaffId String
  createdAt        DateTime    @default(now())
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  order            Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  menuItem         MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  createdByStaff   Staff       @relation("WasteRecordByStaff", fields: [createdByStaffId], references: [id], onDelete: Restrict)

  @@index([branchId, createdAt])
  @@index([menuItemId])
}

// 9. Scheduled Business Summaries
model ScheduledBusinessSummary {
  id           String          @id @default(cuid())
  tenantId     String
  branchId     String? // null if tenant-wide
  frequency    ReportFrequency
  reportDate   DateTime // e.g. end of day/week
  snapshotJson Json // The complete business insight response
  status       String // e.g. GENERATED, FAILED
  createdAt    DateTime        @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, reportDate])
}
