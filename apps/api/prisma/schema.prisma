generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_SERVICE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PLACED
  CONFIRMED
  IN_KITCHEN
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum KitchenItemStatus {
  PENDING
  IN_PROGRESS
  READY
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  MIXED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayerType {
  CUSTOMER
  STAFF_ADJUSTMENT
}

enum SplitType {
  BY_AMOUNT
  BY_ITEMS
  BY_PEOPLE
}

enum TaxClass {
  FOOD
  BEVERAGE
  OTHER
}

enum StaffRoleCode {
  OWNER
  MANAGER
  CASHIER
  WAITER
  CHEF
  KITCHEN_LEAD
}

enum GlobalRole {
  SAAS_OWNER
}

enum NotificationType {
  ORDER_STATUS
  PROMO
  SYSTEM
  REPORT
}

enum ServiceRequestType {
  CALL_WAITER
  WATER
  CUTLERY
  BILL_REQUEST
  NAPKINS
  PAYMENT_TERMINAL
  OTHER
}

enum ServiceRequestStatus {
  NEW
  CLAIMED
  COMPLETED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  DISABLED
  EXPIRED
}

enum LoyaltyLedgerEntryType {
  EARN
  REDEEM
  REFUND_REVERSAL
  EXPIRE
  MANUAL_ADJUSTMENT
}

enum LoyaltyRewardRedemptionStatus {
  ISSUED
  REDEEMED
  CANCELLED
  EXPIRED
}

enum GeoFenceAppliesTo {
  CUSTOMER_ORDERING
  PAYMENT_START
  STAFF_LOGIN
}

enum OrderSource {
  USER_APP
  POS_DASHBOARD
  WAITER_QUICK_ADD
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum WasteType {
  WASTE
  REMAKE
}

enum ReportFrequency {
  DAILY
  WEEKLY
}

enum WasteReason {
  BURNT
  WRONG_ITEM
  CUSTOMER_CHANGE
  DAMAGED
  QUALITY_ISSUE
  OTHER
}

enum DeviceType {
  KDS
  WAITER
  POS
  ADMIN
  CDS
  OTHER
}

enum AccessTagType {
  QR
  NFC
}

enum ServiceChargeType {
  PERCENT
  FIXED
}

enum StockAdjustmentSource {
  MANUAL
  ORDER_AUTO
  WASTE
  CORRECTION
  DELIVERY
}

enum LowStockAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum GiftCardTransactionType {
  ISSUED
  REDEEMED
  ADJUSTED
  EXPIRED
}

enum TableShape {
  RECTANGLE
  CIRCLE
  SQUARE
  L_SHAPE
}

model Tenant {
  id                         String                      @id @default(cuid())
  name                       String
  ownerName                  String?
  ownerPhone                 String?
  ownerEmail                 String?
  createdAt                  DateTime                    @default(now())
  isActive                   Boolean                     @default(true)
  branches                   Branch[]
  users                      User[]
  staff                      Staff[]
  roles                      Role[]
  taxRules                   TaxRule[]
  categories                 Category[]
  menuItems                  MenuItem[]
  inventoryItems             InventoryItem[]
  kitchenStations            KitchenStation[]
  sessions                   Session[]
  orders                     Order[]
  orderItems                 OrderItem[]
  orderStatusHistory         OrderStatusHistory[]
  payments                   Payment[]
  refunds                    Refund[]
  reviews                    Review[]
  notifications              Notification[]
  expenses                   Expense[]
  analyticsDailyBranch       AnalyticsDailyBranch[]
  serviceRequests            ServiceRequest[]
  shifts                     Shift[]
  tills                      Till[]
  auditLogs                  AuditLog[]
  discounts                  Discount[]
  coupons                    Coupon[]
  giftCards                  GiftCard[]
  staffAttendance            StaffAttendance[]
  geoFencingRules            GeoFencingRule[]
  branchDevices              BranchDevice[]
  tableAccessTags            TableAccessTag[]
  branchSettings             BranchSettings[]
  stockAdjustments           StockAdjustment[]
  lowStockAlerts             LowStockAlert[]
  couponRedemptions          CouponRedemption[]
  giftCardTransactions       GiftCardTransaction[]
  recommendationStats        RecommendationStat[]
  recommendationLogs         RecommendationLog[]
  menuChatLogs               MenuChatLog[]
  demandForecastLogs         DemandForecastLog[]
  reviewSentimentLogs        ReviewSentimentLog[]
  businessInsightLogs        BusinessInsightLog[]
  favoriteMenuItems          MenuItemFavorite[]
  operationalEventLogs       OperationalEventLog[]
  paymentEventLogs           PaymentEventLog[]
  loyaltyPrograms            LoyaltyProgram[]
  loyaltyAccounts            LoyaltyAccount[]
  loyaltyLedgerEntries       LoyaltyLedgerEntry[]
  loyaltyRewards             LoyaltyReward[]
  loyaltyRedemptions         LoyaltyRewardRedemption[]
  wasteRecords               WasteRecord[]
  demandForecastAccuracies   DemandForecastAccuracy[]
  recommendationInteractions RecommendationInteraction[]
  scheduledBusinessSummaries ScheduledBusinessSummary[]
  subscription               TenantSubscription?
  saasInvoices               SaasInvoice[]
}

model Branch {
  id                         String                      @id @default(cuid())
  tenantId                   String
  name                       String
  location                   String
  latitude                   Decimal?                    @db.Decimal(9, 6)
  longitude                  Decimal?                    @db.Decimal(9, 6)
  geofenceRadiusM            Int                         @default(100)
  geofenceEnabled            Boolean                     @default(false)
  timezone                   String                      @default("UTC")
  isActive                   Boolean                     @default(true)
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tables                     Table[]
  staff                      Staff[]
  categories                 Category[]
  menuItems                  MenuItem[]
  inventoryItems             InventoryItem[]
  kitchenStations            KitchenStation[]
  sessions                   Session[]
  orders                     Order[]
  orderItems                 OrderItem[]
  orderStatusHistory         OrderStatusHistory[]
  payments                   Payment[]
  refunds                    Refund[]
  taxRules                   TaxRule[]
  reviews                    Review[]
  notifications              Notification[]
  expenses                   Expense[]
  analyticsDailyBranch       AnalyticsDailyBranch[]
  serviceRequests            ServiceRequest[]
  shifts                     Shift[]
  auditLogs                  AuditLog[]
  discounts                  Discount[]
  staffAttendance            StaffAttendance[]
  geoFencingRules            GeoFencingRule[]
  branchDevices              BranchDevice[]
  tableAccessTags            TableAccessTag[]
  branchSettings             BranchSettings?
  stockAdjustments           StockAdjustment[]
  lowStockAlerts             LowStockAlert[]
  couponRedemptions          CouponRedemption[]
  giftCardTransactions       GiftCardTransaction[]
  recommendationStats        RecommendationStat[]
  recommendationLogs         RecommendationLog[]
  menuChatLogs               MenuChatLog[]
  demandForecastLogs         DemandForecastLog[]
  reviewSentimentLogs        ReviewSentimentLog[]
  businessInsightLogs        BusinessInsightLog[]
  favoriteMenuItems          MenuItemFavorite[]
  operationalEventLogs       OperationalEventLog[]
  paymentEventLogs           PaymentEventLog[]
  loyaltyLedgerEntries       LoyaltyLedgerEntry[]
  wasteRecords               WasteRecord[]
  demandForecastAccuracies   DemandForecastAccuracy[]
  recommendationInteractions RecommendationInteraction[]
  scheduledBusinessSummaries ScheduledBusinessSummary[]

  @@index([tenantId])
}

model Table {
  id                  String           @id @default(cuid())
  branchId            String
  tableCode           String
  capacity            Int
  status              TableStatus      @default(AVAILABLE)
  locationDescription String?
  lastOccupiedTime    DateTime?
  totalOrders         Int              @default(0)
  lastSessionId       String?
  // Layout metadata for floor map
  zone                String?
  posX                Int?
  posY                Int?
  shape               TableShape?
  branch              Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  sessions            Session[]        @relation("TableSessions")
  lastSession         Session?         @relation("TableLastSession", fields: [lastSessionId], references: [id], onDelete: SetNull)
  serviceRequests     ServiceRequest[]
  accessTags          TableAccessTag[]

  @@unique([branchId, tableCode])
  @@index([branchId, status])
}

model User {
  id                         String                      @id @default(cuid())
  tenantId                   String?
  globalRole                 GlobalRole?
  name                       String
  phone                      String
  email                      String?
  passwordHash               String?
  preferencesJson            Json?
  lastVisitAt                DateTime?
  createdAt                  DateTime                    @default(now())
  isBlocked                  Boolean                     @default(false)
  tenant                     Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  sessions                   Session[]
  sessionParts               SessionParticipant[]
  orders                     Order[]
  reviews                    Review[]
  notifications              Notification[]
  refreshTokens              RefreshToken[]
  userItemStats              UserItemStat[]
  couponRedemptions          CouponRedemption[]
  recommendationLogs         RecommendationLog[]
  menuChatLogs               MenuChatLog[]
  loyaltyAccounts            LoyaltyAccount[]
  favoriteMenuItems          MenuItemFavorite[]
  recommendationInteractions RecommendationInteraction[]

  @@index([phone])
  @@index([email])
  @@index([tenantId])
  @@index([globalRole])
}

model Staff {
  id                     String                @id @default(cuid())
  tenantId               String
  branchId               String
  name                   String
  phone                  String
  email                  String
  primaryRole            StaffRoleCode
  passwordHash           String
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch                 Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  roleAssignments        StaffRoleAssignment[]
  createdSessions        Session[]             @relation("SessionCreatedByStaff")
  claimedServiceRequests ServiceRequest[]      @relation("ServiceRequestClaimedByStaff")
  notifications          Notification[]
  shiftAssignments       Shift[]               @relation("ShiftOwnedByStaff")
  tillClosures           Till[]                @relation("TillClosedByStaff")
  auditLogs              AuditLog[]
  attendanceRecords      StaffAttendance[]
  orderStatusChanges     OrderStatusHistory[]  @relation("OrderStatusChangedByStaff")
  refundsInitiated       Refund[]              @relation("RefundCreatedByStaff")
  expensesCreated        Expense[]             @relation("ExpenseCreatedByStaff")
  stockAdjustments       StockAdjustment[]     @relation("StockAdjustmentByStaff")
  giftCardTransactions   GiftCardTransaction[] @relation("GiftCardTransactionByStaff")
  wasteRecords           WasteRecord[]         @relation("WasteRecordByStaff")
  demandForecastLogs     DemandForecastLog[]   @relation("DemandForecastRequestedByStaff")
  reviewSentimentLogs    ReviewSentimentLog[]  @relation("ReviewSentimentRequestedByStaff")
  businessInsightLogs    BusinessInsightLog[]  @relation("BusinessInsightRequestedByStaff")
  operationalEventLogs   OperationalEventLog[] @relation("OperationalEventActorStaff")
  assignedOrders         Order[]               @relation("OrderAssignedWaiter")

  @@index([branchId, primaryRole])
}

model Role {
  id               String                @id @default(cuid())
  tenantId         String
  roleName         String
  isActive         Boolean               @default(true)
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permissions      RolePermission[]
  staffAssignments StaffRoleAssignment[]

  @@unique([tenantId, roleName])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  roleLinks   RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model StaffRoleAssignment {
  staffId String
  roleId  String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([staffId, roleId])
}

model Session {
  id                         String                      @id @default(cuid())
  tenantId                   String
  branchId                   String
  tableId                    String
  userId                     String?
  startTime                  DateTime                    @default(now())
  endTime                    DateTime?
  status                     SessionStatus               @default(ACTIVE)
  guestCount                 Int
  createdByStaffId           String?
  notes                      String?
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch                     Branch                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  table                      Table                       @relation("TableSessions", fields: [tableId], references: [id], onDelete: Restrict)
  user                       User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdByStaff             Staff?                      @relation("SessionCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  participants               SessionParticipant[]
  orders                     Order[]
  payments                   Payment[]
  serviceRequests            ServiceRequest[]
  tableLastUsedBy            Table[]                     @relation("TableLastSession")
  recommendationLogs         RecommendationLog[]
  menuChatLogs               MenuChatLog[]
  recommendationInteractions RecommendationInteraction[]

  @@index([tableId, status])
  @@index([branchId, startTime])
}

model SessionParticipant {
  id          String         @id @default(cuid())
  sessionId   String
  displayName String?
  userId      String?
  session     Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  splits      PaymentSplit[]

  @@index([sessionId])
}

model Category {
  id                  String               @id @default(cuid())
  tenantId            String
  branchId            String?
  parentCategoryId    String?
  name                String
  description         String?
  displayOrder        Int                  @default(0)
  isActive            Boolean              @default(true)
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  parentCategory      Category?            @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories     Category[]           @relation("CategoryHierarchy")
  menuItems           MenuItem[]
  recommendationStats RecommendationStat[]

  @@index([tenantId])
  @@index([branchId])
}

model MenuItem {
  id                         String                      @id @default(cuid())
  tenantId                   String
  branchId                   String?
  categoryId                 String
  name                       String
  description                String?
  ingredients                String?
  price                      Decimal                     @db.Decimal(12, 2)
  isActive                   Boolean                     @default(true)
  isUnavailable              Boolean                     @default(false)
  dietaryInfo                String?
  allergensJson              Json?
  isVegetarian               Boolean                     @default(false)
  isSpicy                    Boolean                     @default(false)
  prepTimeMinutes            Int?
  imageUrl                   String?
  taxClass                   TaxClass                    @default(FOOD)
  defaultStationId           String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch                     Branch?                     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category                   Category                    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  defaultStation             KitchenStation?             @relation("MenuItemDefaultStation", fields: [defaultStationId], references: [id], onDelete: SetNull)
  additions                  MenuItemAddition[]
  orderItems                 OrderItem[]
  itemReviews                ItemReview[]
  inventoryLinks             MenuItemInventoryMap[]
  userStats                  UserItemStat[]
  topAnalytics               AnalyticsDailyBranch[]      @relation("TopItemAnalytics")
  recommendationsFrom        RecommendationStat[]        @relation("RecommendationFromItem")
  recommendationsTo          RecommendationStat[]        @relation("RecommendationToItem")
  wasteRecords               WasteRecord[]
  favorites                  MenuItemFavorite[]
  recommendationInteractions RecommendationInteraction[]

  @@index([branchId, categoryId])
  @@index([isActive, isUnavailable])
}

model MenuItemAddition {
  id            String   @id @default(cuid())
  menuItemId    String
  name          String
  priceImpact   Decimal  @db.Decimal(12, 2)
  isRequired    Boolean  @default(false)
  maxSelectable Int?
  isActive      Boolean  @default(true)
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model InventoryItem {
  id               String                 @id @default(cuid())
  tenantId         String
  branchId         String
  name             String
  category         String                 @default("OTHER")
  unit             String
  currentStock     Decimal                @db.Decimal(12, 3)
  reorderLevel     Decimal                @db.Decimal(12, 3)
  isActive         Boolean                @default(true)
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  menuItemLinks    MenuItemInventoryMap[]
  stockAdjustments StockAdjustment[]
  lowStockAlerts   LowStockAlert[]

  @@index([branchId, name])
}

model MenuItemInventoryMap {
  menuItemId      String
  inventoryItemId String
  qtyPerItem      Decimal       @db.Decimal(12, 3)
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@id([menuItemId, inventoryItemId])
}

model KitchenStation {
  id               String      @id @default(cuid())
  tenantId         String
  branchId         String
  code             String
  name             String
  displayOrder     Int         @default(0)
  isActive         Boolean     @default(true)
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  orderItems       OrderItem[]
  defaultMenuItems MenuItem[]  @relation("MenuItemDefaultStation")

  @@unique([branchId, code])
  @@index([branchId, isActive])
}

model Order {
  id                     String                @id @default(cuid())
  tenantId               String
  branchId               String
  sessionId              String
  userId                 String?
  orderDateTime          DateTime              @default(now())
  orderStatus            OrderStatus           @default(PLACED)
  subtotalAmount         Decimal               @db.Decimal(12, 2)
  taxAmount              Decimal               @db.Decimal(12, 2)
  serviceChargeAmount    Decimal               @db.Decimal(12, 2)
  discountAmount         Decimal               @db.Decimal(12, 2)
  totalAmount            Decimal               @db.Decimal(12, 2)
  paymentStatus          OrderPaymentStatus    @default(UNPAID)
  specialInstructions    String?
  source                 OrderSource
  taxSnapshotJson        Json?
  idempotencyKey         String?
  assignedWaiterId       String?
  // Edit/audit tracking
  editedAt               DateTime?
  lastEditedByStaffId    String?
  // Inventory decrement guard
  inventoryDecrementedAt DateTime?
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch                 Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  session                Session               @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  user                   User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedWaiter         Staff?                @relation("OrderAssignedWaiter", fields: [assignedWaiterId], references: [id], onDelete: SetNull)
  orderItems             OrderItem[]
  payments               Payment[]
  refunds                Refund[]
  reviews                Review[]
  statusHistory          OrderStatusHistory[]
  couponRedemptions      CouponRedemption[]
  giftCardTransactions   GiftCardTransaction[]
  loyaltyLedgerEntries   LoyaltyLedgerEntry[]
  wasteRecords           WasteRecord[]

  @@unique([idempotencyKey])
  @@index([branchId, orderDateTime])
  @@index([orderStatus])
  @@index([sessionId])
  @@index([assignedWaiterId, orderStatus])
}

model OrderItem {
  id                  String            @id @default(cuid())
  orderId             String
  tenantId            String
  branchId            String
  menuItemId          String
  quantity            Int
  itemBasePrice       Decimal           @db.Decimal(12, 2)
  lineDiscountAmount  Decimal           @db.Decimal(12, 2)
  lineTaxAmount       Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(12, 2)
  specializationsJson Json?
  kitchenStatus       KitchenItemStatus @default(PENDING)
  stationId           String?
  startedAt           DateTime?
  readyAt             DateTime?
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch              Branch            @relation(fields: [branchId], references: [id], onDelete: Restrict)
  menuItem            MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  station             KitchenStation?   @relation(fields: [stationId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([menuItemId])
  @@index([stationId])
}

model OrderStatusHistory {
  id               String       @id @default(cuid())
  orderId          String
  tenantId         String
  branchId         String
  fromStatus       OrderStatus?
  toStatus         OrderStatus
  reason           String?
  changedAt        DateTime     @default(now())
  changedByStaffId String?
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch           Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  changedByStaff   Staff?       @relation("OrderStatusChangedByStaff", fields: [changedByStaffId], references: [id], onDelete: SetNull)

  @@index([orderId, changedAt])
  @@index([branchId, changedAt])
}

model Payment {
  id                   String               @id @default(cuid())
  tenantId             String
  branchId             String
  orderId              String
  sessionId            String
  amount               Decimal              @db.Decimal(12, 2)
  paymentMethod        PaymentMethod
  paymentReference     String?
  paymentDate          DateTime             @default(now())
  paymentStatus        PaymentStatus        @default(PENDING)
  payerType            PayerType            @default(CUSTOMER)
  tipAmount            Decimal?             @db.Decimal(12, 2)
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  order                Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  session              Session              @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  splits               PaymentSplit[]
  refunds              Refund[]
  loyaltyLedgerEntries LoyaltyLedgerEntry[]

  @@index([orderId])
  @@index([paymentStatus])
  @@unique([orderId, paymentReference])
}

model PaymentSplit {
  id            String              @id @default(cuid())
  paymentId     String
  splitType     SplitType
  participantId String?
  amount        Decimal             @db.Decimal(12, 2)
  payment       Payment             @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  participant   SessionParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([paymentId])
}

model Refund {
  id                   String               @id @default(cuid())
  tenantId             String
  branchId             String
  orderId              String
  paymentId            String
  amount               Decimal              @db.Decimal(12, 2)
  status               RefundStatus         @default(PENDING)
  providerRefundId     String?
  providerStatus       String?
  reason               String?
  createdAt            DateTime             @default(now())
  createdByStaffId     String?
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  order                Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment              Payment              @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  createdByStaff       Staff?               @relation("RefundCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  loyaltyLedgerEntries LoyaltyLedgerEntry[]

  @@index([paymentId])
  @@index([orderId])
  @@unique([providerRefundId])
}

model TaxRule {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String
  taxClass    TaxClass
  ratePercent Decimal  @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId, isActive])
}

model Review {
  id            String           @id @default(cuid())
  tenantId      String
  branchId      String
  orderId       String
  userId        String?
  overallRating Int
  comment       String?
  createdAt     DateTime         @default(now())
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch        Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  itemReviews   ItemReview[]
  issueTags     ReviewIssueTag[]

  @@index([orderId])
  @@index([userId])
}

model ItemReview {
  id         String   @id @default(cuid())
  reviewId   String
  menuItemId String
  rating     Int
  comment    String?
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([reviewId])
  @@index([menuItemId])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  branchId  String
  userId    String?
  staffId   String?
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch    Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  staff     Staff?           @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([staffId])
  @@index([branchId, createdAt])
}

model Expense {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  category         String
  amount           Decimal  @db.Decimal(12, 2)
  expenseDate      DateTime
