    "test:critical": "npm run test:branch-access && npm run test:public-order && npm run test:payment-safety && npm run test:webhook-signature && npm run test:inventory-transactions && npm run test:dto-validation && npm run test:ai-output-validation && npm run test:business-insights && npm run test:demand-forecast && npm run test:waiter-order-assignment && npm run test:waiter-payment-permissions && npm run test:geofencing && npm run test:security-hardening && npm run test:otp-sms",
