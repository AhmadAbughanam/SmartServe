NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
AI_PORT=8000
POSTGRES_PORT=5435
REDIS_PORT=6380
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_DB=smart_restaurant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/smart_restaurant?schema=public
REDIS_URL=redis://localhost:6380
JWT_SECRET=change-me-before-production
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_AI_BASE_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8000
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret
GEOFENCING_ENABLED=true
GEOFENCING_DEMO_BYPASS=false
GEOFENCING_DEFAULT_RADIUS_M=100
GEOFENCING_MAX_ACCURACY_M=1000
# Stripe is optional. Set only when PAYMENT_PROVIDER=stripe.
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
# Optional backend-only Hugging Face LLM integration.
# HF_TOKEN=hf_your_token_here
# HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:fastest
# HF_BASE_URL=https://router.huggingface.co/v1
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=smart-restaurant
